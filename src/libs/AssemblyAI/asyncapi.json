{
  "asyncapi": "3.0.0",
  "info": {
    "title": "AssemblyAI Streaming Speech-to-Text",
    "version": "1.0.0",
    "description": "AssemblyAI v3 real-time speech-to-text streaming WebSocket API."
  },
  "servers": {
    "production": {
      "host": "streaming.assemblyai.com",
      "pathname": "/v3/ws",
      "protocol": "wss",
      "description": "AssemblyAI production streaming endpoint"
    }
  },
  "channels": {
    "streaming": {
      "address": "/v3/ws",
      "messages": {
        "updateConfiguration": {
          "$ref": "#/components/messages/UpdateConfiguration"
        },
        "forceEndpoint": {
          "$ref": "#/components/messages/ForceEndpoint"
        },
        "sessionTermination": {
          "$ref": "#/components/messages/SessionTermination"
        },
        "sessionBegins": {
          "$ref": "#/components/messages/SessionBegins"
        },
        "speechStarted": {
          "$ref": "#/components/messages/SpeechStarted"
        },
        "turn": {
          "$ref": "#/components/messages/Turn"
        },
        "speakerRevision": {
          "$ref": "#/components/messages/SpeakerRevision"
        },
        "termination": {
          "$ref": "#/components/messages/Termination"
        },
        "error": {
          "$ref": "#/components/messages/Error"
        },
        "keepAlive": {
          "$ref": "#/components/messages/KeepAlive"
        }
      }
    }
  },
  "operations": {
    "sendUpdateConfiguration": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/streaming"
      },
      "summary": "Update streaming configuration parameters during an active session.",
      "messages": [
        {
          "$ref": "#/channels/streaming/messages/updateConfiguration"
        }
      ]
    },
    "sendForceEndpoint": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/streaming"
      },
      "summary": "Manually force an endpoint in the transcription.",
      "messages": [
        {
          "$ref": "#/channels/streaming/messages/forceEndpoint"
        }
      ]
    },
    "sendSessionTermination": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/streaming"
      },
      "summary": "Gracefully terminate the streaming session.",
      "messages": [
        {
          "$ref": "#/channels/streaming/messages/sessionTermination"
        }
      ]
    },
    "receiveSessionBegins": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/streaming"
      },
      "summary": "Receive confirmation that the streaming session has started.",
      "messages": [
        {
          "$ref": "#/channels/streaming/messages/sessionBegins"
        }
      ]
    },
    "receiveTurn": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/streaming"
      },
      "summary": "Receive a turn-based transcription result.",
      "messages": [
        {
          "$ref": "#/channels/streaming/messages/turn"
        }
      ]
    },
    "receiveSpeechStarted": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/streaming"
      },
      "summary": "Receive notification that speech has been detected.",
      "messages": [
        {
          "$ref": "#/channels/streaming/messages/speechStarted"
        }
      ]
    },
    "receiveSpeakerRevision": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/streaming"
      },
      "summary": "Receive revised speaker labels after session termination.",
      "messages": [
        {
          "$ref": "#/channels/streaming/messages/speakerRevision"
        }
      ]
    },
    "receiveTermination": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/streaming"
      },
      "summary": "Receive confirmation that the session has been terminated.",
      "messages": [
        {
          "$ref": "#/channels/streaming/messages/termination"
        }
      ]
    },
    "receiveError": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/streaming"
      },
      "summary": "Receive a server-emitted error frame before the connection is closed.",
      "messages": [
        {
          "$ref": "#/channels/streaming/messages/error"
        }
      ]
    },
    "sendKeepAlive": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/streaming"
      },
      "summary": "Send a keep-alive ping to reset inactivity_timeout.",
      "messages": [
        {
          "$ref": "#/channels/streaming/messages/keepAlive"
        }
      ]
    }
  },
  "components": {
    "schemas": {
      "UpdateConfigurationPayload": {
        "type": "object",
        "description": "Update streaming configuration parameters during an active session.",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Message type identifier.",
            "enum": ["UpdateConfiguration"]
          },
          "end_of_turn_confidence_threshold": {
            "type": "number",
            "description": "Confidence threshold (0-1) for detecting end of turn.",
            "nullable": true
          },
          "min_turn_silence": {
            "type": "integer",
            "description": "Minimum silence duration in ms when confident about end of turn.",
            "nullable": true
          },
          "max_turn_silence": {
            "type": "integer",
            "description": "Maximum silence in ms before end of turn is triggered.",
            "nullable": true
          },
          "interruption_delay": {
            "type": "integer",
            "description": "How soon the first partial is emitted, in milliseconds.",
            "nullable": true
          },
          "vad_threshold": {
            "type": "number",
            "description": "Confidence threshold (0.0 to 1.0) for classifying audio frames as speech.",
            "nullable": true
          },
          "mode": {
            "type": "string",
            "description": "Latency and accuracy preset.",
            "enum": ["max_accuracy", "min_latency", "balanced"],
            "nullable": true
          },
          "prompt": {
            "type": "string",
            "description": "Contextual prompt describing the audio domain, scenario, or conversation details.",
            "nullable": true
          },
          "agent_context": {
            "type": "string",
            "description": "Your voice agent's most recent spoken reply. Used as context for the next user turn.",
            "nullable": true
          },
          "keyterms_prompt": {
            "type": "array",
            "description": "Words and phrases to improve recognition accuracy.",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "continuous_partials": {
            "type": "boolean",
            "description": "Whether to emit additional partial transcripts during long turns.",
            "nullable": true
          }
        }
      },
      "ForceEndpointPayload": {
        "type": "object",
        "description": "Manually force an endpoint in the transcription.",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Message type identifier.",
            "enum": ["ForceEndpoint"]
          }
        }
      },
      "SessionTerminationPayload": {
        "type": "object",
        "description": "Gracefully terminate the streaming session.",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Message type identifier.",
            "enum": ["Terminate"]
          }
        }
      },
      "SessionBeginsPayload": {
        "type": "object",
        "description": "Server event indicating the streaming session has started.",
        "required": ["type", "id", "expires_at"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Message type identifier.",
            "enum": ["Begin"]
          },
          "id": {
            "type": "string",
            "description": "Unique session identifier."
          },
          "expires_at": {
            "type": "integer",
            "description": "Unix timestamp indicating when the session will expire."
          }
        }
      },
      "SpeechStartedPayload": {
        "type": "object",
        "description": "Server event indicating speech has been detected.",
        "required": ["type", "timestamp", "confidence"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Message type identifier.",
            "enum": ["SpeechStarted"]
          },
          "timestamp": {
            "type": "integer",
            "description": "Audio timestamp in milliseconds where speech was detected."
          },
          "confidence": {
            "type": "number",
            "description": "Speech detection confidence."
          }
        }
      },
      "Word": {
        "type": "object",
        "description": "Word-level transcription detail.",
        "required": ["text", "start", "end", "confidence", "word_is_final"],
        "properties": {
          "text": {
            "type": "string",
            "description": "The transcribed word."
          },
          "start": {
            "type": "integer",
            "description": "Start time in milliseconds."
          },
          "end": {
            "type": "integer",
            "description": "End time in milliseconds."
          },
          "confidence": {
            "type": "number",
            "description": "Confidence score (0.0 to 1.0)."
          },
          "word_is_final": {
            "type": "boolean",
            "description": "Whether the word is finalized."
          },
          "speaker": {
            "type": "string",
            "description": "Speaker label for this final word (when speaker_labels is enabled)."
          }
        }
      },
      "TurnPayload": {
        "type": "object",
        "description": "Turn-based transcription result.",
        "required": ["type", "turn_order", "turn_is_formatted", "end_of_turn", "transcript", "end_of_turn_confidence", "words"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Message type identifier.",
            "enum": ["Turn"]
          },
          "turn_order": {
            "type": "integer",
            "description": "Order of this turn in the conversation."
          },
          "turn_is_formatted": {
            "type": "boolean",
            "description": "Whether this turn has been formatted."
          },
          "end_of_turn": {
            "type": "boolean",
            "description": "Whether this marks the end of a turn."
          },
          "transcript": {
            "type": "string",
            "description": "Transcript of all finalized words in the turn."
          },
          "utterance": {
            "type": "string",
            "description": "Finalized text at the moment a pause in speech is detected."
          },
          "language_code": {
            "type": "string",
            "description": "Detected language code (when language detection is enabled)."
          },
          "language_confidence": {
            "type": "number",
            "description": "Language detection confidence (0-1)."
          },
          "speaker_label": {
            "type": "string",
            "description": "Speaker label (when speaker_labels is enabled)."
          },
          "end_of_turn_confidence": {
            "type": "number",
            "description": "Confidence this is end of turn (0-1)."
          },
          "words": {
            "type": "array",
            "description": "Word-level details.",
            "items": {
              "$ref": "#/components/schemas/Word"
            }
          }
        }
      },
      "SpeakerRevisionPayload": {
        "type": "object",
        "description": "Server event containing corrected speaker labels after termination.",
        "required": ["type", "revisions"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Message type identifier.",
            "enum": ["SpeakerRevision"]
          },
          "revisions": {
            "type": "array",
            "description": "Turns whose speaker labels changed.",
            "items": {
              "$ref": "#/components/schemas/SpeakerRevision"
            }
          }
        }
      },
      "SpeakerRevision": {
        "type": "object",
        "description": "Corrected speaker labels for a single turn.",
        "required": ["turn_order", "speaker_label", "words"],
        "properties": {
          "turn_order": {
            "type": "integer",
            "description": "Order of the revised turn in the conversation."
          },
          "speaker_label": {
            "type": "string",
            "description": "Corrected speaker label for the turn."
          },
          "words": {
            "type": "array",
            "description": "Revised word-level speaker attribution.",
            "items": {
              "$ref": "#/components/schemas/Word"
            }
          }
        }
      },
      "TerminationPayload": {
        "type": "object",
        "description": "Server event confirming session termination with statistics.",
        "required": ["type", "audio_duration_seconds", "session_duration_seconds"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Message type identifier.",
            "enum": ["Termination"]
          },
          "audio_duration_seconds": {
            "type": "integer",
            "description": "Duration of audio in seconds."
          },
          "session_duration_seconds": {
            "type": "integer",
            "description": "Duration of session in seconds."
          }
        }
      },
      "ErrorPayload": {
        "type": "object",
        "description": "Server-emitted validation, authentication or quota error. Typically delivered immediately before the WebSocket is closed by the server.",
        "required": ["type", "error_code", "error"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Message type identifier.",
            "enum": ["Error"]
          },
          "error_code": {
            "type": "integer",
            "description": "AssemblyAI numeric error code (e.g. 3006 for invalid input, 4003 for unauthorized)."
          },
          "error": {
            "type": "string",
            "description": "Human-readable error message."
          }
        }
      },
      "KeepAlivePayload": {
        "type": "object",
        "description": "Keep-alive ping that resets the server-side `inactivity_timeout` timer. Only needed when `inactivity_timeout` is set and audio is paused without terminating the session.",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Message type identifier.",
            "enum": ["KeepAlive"]
          }
        }
      }
    },
    "messages": {
      "UpdateConfiguration": {
        "name": "UpdateConfiguration",
        "summary": "Update streaming configuration.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/UpdateConfigurationPayload"
        }
      },
      "ForceEndpoint": {
        "name": "ForceEndpoint",
        "summary": "Force an endpoint in transcription.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/ForceEndpointPayload"
        }
      },
      "SessionTermination": {
        "name": "SessionTermination",
        "summary": "Terminate the session.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/SessionTerminationPayload"
        }
      },
      "SessionBegins": {
        "name": "SessionBegins",
        "summary": "Session started confirmation.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/SessionBeginsPayload"
        }
      },
      "Turn": {
        "name": "Turn",
        "summary": "Turn-based transcription result.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/TurnPayload"
        }
      },
      "SpeechStarted": {
        "name": "SpeechStarted",
        "summary": "Speech started notification.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/SpeechStartedPayload"
        }
      },
      "SpeakerRevision": {
        "name": "SpeakerRevision",
        "summary": "Revised speaker labels.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/SpeakerRevisionPayload"
        }
      },
      "Termination": {
        "name": "Termination",
        "summary": "Session terminated confirmation.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/TerminationPayload"
        }
      },
      "Error": {
        "name": "Error",
        "summary": "Server-emitted error frame (validation, auth, quota, etc.).",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/ErrorPayload"
        }
      },
      "KeepAlive": {
        "name": "KeepAlive",
        "summary": "Keep-alive ping to reset inactivity_timeout.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/KeepAlivePayload"
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "httpApiKey",
        "name": "Authorization",
        "in": "header",
        "description": "AssemblyAI API key"
      }
    }
  }
}
